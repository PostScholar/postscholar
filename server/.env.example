# Database
DATABASE_URL=postgresql://localhost/postscholar

# Auth (generate a long random string for production)
JWT_SECRET=change-me-in-production

# Frontend URL — used for CORS, password reset links, ORCID callback
CLIENT_URL=http://localhost:3001

# Server
PORT=3000
NODE_ENV=development

# ORCID (https://orcid.org/developer-tools)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=PostScholar <noreply@postscholar.org>

# Optional: error tracking (https://sentry.io)
SENTRY_DSN=

# Rate limits (optional — defaults are stricter in production)
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_GENERAL_MAX=100
